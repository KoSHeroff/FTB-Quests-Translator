# Скопируйте в .env и укажите ключ: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
# Модель для перевода (рекомендуется gpt-4o-mini — дёшево и достаточно для текста квестов)
OPENAI_MODEL=gpt-4o-mini
# Необязательно: свой endpoint (прокси, Azure OpenAI, совместимый API). По умолчанию — api.openai.com
# Пример: https://api.openai.com/v1  или https://your-resource.openai.azure.com/openai/deployments/your-deployment
OPENAI_BASE_URL=
